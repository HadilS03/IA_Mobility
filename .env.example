# --- Base de données PostgreSQL ---
# Copier ce fichier en .env puis adapter les valeurs.
# Le vrai .env n'est JAMAIS commité (voir .gitignore).
POSTGRES_USER=ia_mobility
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ia_mobility

# Hôte/port utilisés par le service Python pour joindre la base.
# En local (hors Docker) : localhost. Dans docker-compose : le nom du service "db".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Port d'exposition de la base du conteneur côté machine hôte.
# 5433 par défaut pour ne pas entrer en conflit avec un PostgreSQL local (5432).
DB_PORT=5433

# --- Collecte Open Data Bordeaux Métropole ---
# Clé d'accès publique à l'API GeoJSON des parkings.
BORDEAUX_API_KEY=UFM1S7RTLN

# --- Sécurité des endpoints de données ---
# Clé exigée dans l'en-tête X-API-Key pour /parkings, /historique et /dataset.
# À remplacer par une vraie valeur secrète dans le .env réel (non versionné).
DATA_API_KEY=change-me
